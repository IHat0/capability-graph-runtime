{
  "schema_version": "cgr.quantum-sweagent-tool-image-build/1.1.0",
  "base_image_policy": "caller-supplied-immutable-repository-digest",
  "dockerfile": "Dockerfile",
  "requirements_lock": "requirements.lock",
  "required_commands": ["bash", "git", "pipx", "swerex-remote"],
  "required_sweagent_commit": "0f3acafacabc0def8cc76b4e48acb4b6cf302cb9",
